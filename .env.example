# Copy this to .env and fill in real values, or set as system environment variables.
# For local dev you can also use src/main/resources/application-local.yml (gitignored).

DB_URL=jdbc:postgresql://your-host:6543/postgres?sslmode=require&prepareThreshold=0
DB_USERNAME=postgres.your_project_ref
DB_PASSWORD=your_db_password

SUPABASE_JWT_SECRET=your_supabase_jwt_secret
SUPABASE_PROJECT_URL=https://your_project_ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
